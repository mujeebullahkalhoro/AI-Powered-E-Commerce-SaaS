PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27018/ai-ecommerce?replicaSet=rs0
JWT_ACCESS_SECRET=your_access_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_ACCESS_EXPIRES_IN=2h
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
GOOGLE_API_KEY=your_google_api_key
GROQ_API_KEY=your_groq_api_key
CLIENT_URL=http://localhost:3000
API_PUBLIC_URL=http://127.0.0.1:5000
USE_LOCAL_UPLOAD=true
USE_VECTOR_SEARCH=false   # set to true only on MongoDB Atlas with vector index created
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password_or_app_password
SMTP_FROM="ShopAI <no-reply@yourdomain.com>"
